# =============================================================================
# Eclipse Backend - 환경변수 예시 파일
# 이 파일을 복사하여 .env 를 만들고 실제 값을 입력하세요.
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# 공통 - DB (RDS MySQL 8.0, Private Subnet)
# -----------------------------------------------------------------------------
# RDS 엔드포인트 주소로 교체하세요
DB_URL=jdbc:mysql://<RDS_ENDPOINT>:3306/eclipse?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&characterEncoding=UTF-8
DB_USERNAME=eclipse
DB_PASSWORD=your_db_password_here

# -----------------------------------------------------------------------------
# 공통 - Redis (ElastiCache 7.2, Private Subnet)
# ledger-app, service-app에서 사용 (worker-app은 Redis 미사용)
# -----------------------------------------------------------------------------
REDIS_HOST=<ELASTICACHE_ENDPOINT>
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# JWT 키 경로
# EC2 내부 파일시스템 경로 또는 classpath 경로 지정
# 예: /app/keys/private.pem  또는  classpath:keys/private.pem
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem

# -----------------------------------------------------------------------------
# Anthropic Claude API (service-app, worker-app)
# https://console.anthropic.com/ 에서 발급
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# -----------------------------------------------------------------------------
# KIS (한국투자증권) Open API (service-app, worker-app)
# https://apiportal.koreainvestment.com/ 에서 발급
# -----------------------------------------------------------------------------
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here

# -----------------------------------------------------------------------------
# LS증권 Open API (service-app, worker-app) - 레거시 보존용
# https://openapi.ls-sec.co.kr/ 에서 발급
# -----------------------------------------------------------------------------
LS_BASE_URL=https://openapi.ls-sec.co.kr:8080
LS_WS_URL=wss://openapi.ls-sec.co.kr:9443/websocket
LS_APP_KEY=your_ls_app_key_here
LS_APP_SECRET=your_ls_app_secret_here

# -----------------------------------------------------------------------------
# 수출입은행 환율 API (service-app)
# https://www.koreaexim.go.kr/ir/HPHKIR020M01 에서 발급
# -----------------------------------------------------------------------------
EXIMBANK_BASE_URL=https://oapi.koreaexim.go.kr
EXIMBANK_AUTH_KEY=your_eximbank_auth_key_here

# FINNHUB
# -----------------------------------------------------------------------------
# Finnhub Stock API (service-app)
# https://finnhub.io/dashboard 에서 발급
# -----------------------------------------------------------------------------
FINNHUB_API_KEY=your_finnhub_api_key_here

# -----------------------------------------------------------------------------
# Financial Modeling Prep API (service-app)
# https://financialmodelingprep.com/developer/docs/ 에서 발급
# -----------------------------------------------------------------------------
FMP_API_KEY=your_fmp_api_key_here


EODHD_API_KEY=your_eodhd_api_key_here
